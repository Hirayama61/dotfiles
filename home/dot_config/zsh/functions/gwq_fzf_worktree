# worktree を fzf で選択して cd する ZLE widget
# bindkey: Ctrl+G Ctrl+W
#
# 列挙は gwq list ではなく ~/worktrees の生 FS から。gwq list -g は worktree ごとに git を
# 叩いて branch/commit_hash/is_main を計算し遅い(職場 PC で顕著)が、この widget は path しか
# 要らない。naming `~/worktrees/host/owner/repo/branch...` は wt.sh / WorktreeCreate hook が
# 強制するので FS は gwq と等価な真実(状態監査の真実の源は引き続き gwq。ここは高速ジャンプ専用)。
#
# 再帰 glob(~/worktrees/**/.git)は使わない。Node リポ worktree の node_modules を走査して
# 逆に激遅になる(=今回直したい遅さの再来)。worktree root を見つけたらその中へは降りない。
#
# 表示は branch 先頭 + repo 後置で同一リポの複数 worktree を識別(フルパスだと小画面で末尾
# branch が切れる + 同一リポ同名 branch が repo 違いで衝突しうる)。フルパスは tab 区切りの
# 隠しフィールドにして cd/preview に使う。

emulate -L zsh

local base=$HOME/worktrees
local -a leaves=()
local -a pending=( $base/*/*/*(/N) )   # host/owner/repo の namespace dir 群
local d
# repo dir 配下を BFS で降り、.git を持つ dir = worktree root で降下を止める。これにより
# (a) worktree 内の node_modules 等を走査せず速く、(b) branch の slash 段数に依らず
# (feat/foo/bar 等の多段 slash も)取りこぼさない。wt.sh/hook は naming を強制するが
# branch の slash 数は制限しないため、固定段数で決め打ちしない。
while (( ${#pending} )); do
  d=$pending[1]; shift pending
  if [[ -e $d/.git ]]; then
    leaves+=( $d )
  else
    pending+=( $d/*(/N) )
  fi
done
(( ${#leaves} )) || { zle reset-prompt; return }

local p rel repo branch sel
sel=$(
  for p in $leaves; do
    rel=${p#$base/}
    local -a parts=( "${(@s:/:)rel}" )
    repo=$parts[3]
    branch=${(j:/:)parts[4,-1]}
    printf '%s\t%s\n' "$branch  ⟨$repo⟩" "$p"
  done | fzf --height 40% --layout=reverse --border \
    --delimiter='\t' --with-nth=1 --nth=1 \
    --preview 'git -C {2} log --oneline --graph --decorate -n 20 --color=always 2>/dev/null; echo; git -C {2} -c color.status=always status -sb 2>/dev/null'
)

if [[ -n "$sel" ]]; then
  local worktree=${sel##*$'\t'}
  BUFFER="cd ${worktree/#$HOME/~}"
  zle accept-line
else
  zle reset-prompt
fi

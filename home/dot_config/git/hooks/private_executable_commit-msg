#!/usr/bin/env bash
# commit-msg hook: 機密語ガード + Conventional Commits 検証
#
# 1. ~/.config/git/sensitive-words.txt の各パターンをメッセージ本文に照合
#    (コメント行・verbose diff のシザー以降は除外)
# 2. 1 行目が <type>(<scope>)?(!)?: <desc> 形式か検証
#    type: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert

set -eu

msg_file=$1

words_file="$HOME/.config/git/sensitive-words.txt"
if [ -f "$words_file" ]; then
  # 末尾 CR も除去(被検査側。E-C2 のリスト側 strip と対称。end-anchor の取りこぼし防止)。
  body=$(sed -e '/^#.*>8/,$d' -e '/^#/d' "$msg_file" | tr -d '\r')
  if [ -n "$body" ]; then
    found=0
    while IFS= read -r word || [ -n "$word" ]; do
      # CRLF のリストだと末尾 CR が ERE に混ざり全パターンが無効化される(E-C2)。
      word=${word%$'\r'}
      [[ -z "$word" || "$word" == \#* ]] && continue
      # 不正な ERE を `|| true` で握ると grep のエラー(rc>=2)をマッチ無しと取り違える(E-C1)。
      rc=0
      matches=$(printf '%s\n' "$body" | grep -inE "$word") || rc=$?
      if [ "$rc" -ge 2 ]; then
        echo "ERROR: 機密語パターンが不正な正規表現です(grep rc=$rc): $word" >&2
        echo "~/.config/git/sensitive-words.txt の該当パターンを修正してください。" >&2
        exit 1
      fi
      [ -n "$matches" ] || continue
      if [ "$found" -eq 0 ]; then
        echo "ERROR: 機密語がコミットメッセージに含まれています。コミットを中止しました。" >&2
        echo >&2
        found=1
      fi
      echo "  パターン: $word" >&2
      printf '%s\n' "$matches" | head -5 | sed 's/^/    /' >&2
      echo >&2
    done <"$words_file"
    if [ "$found" -ne 0 ]; then
      echo "誤検知の場合のみ git commit --no-verify で回避してください。" >&2
      exit 1
    fi
  fi
fi

# ローカル commit-msg hook のチェーン実行
#
# core.hooksPath をグローバル設定しているため、各リポの husky/lefthook/標準
# .git/hooks は本来 git 仕様で完全バイパスされる。機密語ガード(security)を
# 通した後、ローカル commit-msg hook があれば exec 委譲し、グローバルの
# Conventional Commits 検証はスキップする(メッセージ整形ポリシーはプロジェクト
# 側を優先し、二重検証・競合を避ける)。exec で置換するため以降の処理は無い。
# ローカル hook が無い場合だけ、下のグローバル CC 検証へフォールスルーする。

# husky v9+
if [ -x ".husky/commit-msg" ]; then
  exec .husky/commit-msg "$msg_file"
fi

# lefthook(PATH 直 → mise の順で検出。設定は lefthook.yml / lefthook.yaml を対象)
if [ -f "lefthook.yml" ] || [ -f "lefthook.yaml" ]; then
  if command -v lefthook >/dev/null 2>&1; then
    exec lefthook run commit-msg "$msg_file"
  elif mise which lefthook >/dev/null 2>&1; then
    exec mise exec -- lefthook run commit-msg "$msg_file"
  fi
fi

# 標準ローカルフック(.git/hooks/commit-msg)
git_dir=$(git rev-parse --git-dir 2>/dev/null || true)
if [ -n "$git_dir" ] && [ -x "$git_dir/hooks/commit-msg" ]; then
  exec "$git_dir/hooks/commit-msg" "$msg_file"
fi

first_line=$(head -1 "$msg_file")

# 自動生成系(merge / revert / rebase fixup 等)はスキップ
if [[ "$first_line" =~ ^(Merge|Revert|fixup!|squash!|amend!) ]]; then
  exit 0
fi

# 空行・コメントのみはスキップ(git 側で別途弾かれる)
if [[ -z "$first_line" || "$first_line" =~ ^# ]]; then
  exit 0
fi

# Conventional Commits パターン
pattern='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\([^)]+\))?!?: .+'

if [[ ! "$first_line" =~ $pattern ]]; then
  cat <<EOF >&2
ERROR: コミットメッセージが Conventional Commits 形式に従っていません。

期待する形式: <type>(<optional-scope>)?: <description>

  例:
    feat: 新機能を追加
    fix(api): リクエストエラーを修正
    refactor!: 破壊的変更
    docs: README を更新

許可される type: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert

実際のメッセージ:
  $first_line
EOF
  exit 1
fi

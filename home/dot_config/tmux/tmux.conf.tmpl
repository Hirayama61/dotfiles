# ============================
# tmux configuration
# ============================

# Prefix を Ctrl+Q に変更
unbind C-b
set -g prefix C-q
bind C-q send-prefix

# 設定リロード(Prefix + r)
bind r source-file ~/.config/tmux/tmux.conf \; display "設定をリロードしました"

# ============================
# ウィンドウ / ペインの基本
# ============================

set -g base-index 1
setw -g pane-base-index 1

set -g renumber-windows on

# 新しいウィンドウで現在のパスを維持
bind c new-window -c "#{pane_current_path}"

# ペイン分割(現在のパスを維持)。| = 左右、_ = 素の上下分割(中段の再分割など稀ケース用)。
bind | split-window -h -c "#{pane_current_path}"
bind _ split-window -v -c "#{pane_current_path}"
unbind '"'
unbind %

# - = フル幅の行を追加して全行を均等高に(行内の左右分割は保持)。通常の縦増設はこちら。
bind - run-shell "~/.config/tmux/split-even.sh v"

# ============================
# ペイン間の移動(Vim 風)
# ============================

bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# ============================
# ウィンドウ間の移動
# ============================

bind n next-window
bind p previous-window

# ============================
# ペインのリサイズ
# ============================

bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# ============================
# マウス操作
# ============================

set -g mouse on

# ============================
# コピーモード(Vim 風)
# ============================

setw -g mode-keys vi
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "pbcopy"

# ============================
# ターミナル
# ============================

# TrueColor(Ghostty 対応)
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",ghostty:Tc,xterm-256color:Tc"

# Neovim の autoread 等に必要
set -g focus-events on

# Escape キーの遅延を減らす(Vim ユーザー向け)
set -sg escape-time 0

set -g history-limit 50000

# ============================
# Window 名 = 現在ディレクトリの basename
# ============================

set -g automatic-rename on
set -g automatic-rename-format '#{b:pane_current_path}'

# ============================
# Pane border 上部に index / コマンド / path 表示
# ============================

set -g pane-border-status top
set -g pane-border-format " #{?pane_active,#[fg={{ .panda.cyan.hex }} bold]●,#[fg={{ .panda.subtle.hex }}]○} #{pane_index}:#{pane_current_command} #{s|$HOME|~|:pane_current_path} "
set -g pane-border-style fg={{ .panda.selection.hex }}
set -g pane-active-border-style fg={{ .panda.cyan.hex }}

# 非アクティブペインの文字色を薄く
set -g window-style "fg={{ .panda.subtle.hex }}"
set -g window-active-style "fg=terminal"

# ============================
# ステータスバー
# ============================

set -g status-position top
set -g status-interval 10
# クォート必須: 裸の #RRGGBB は空白後 # が tmux のコメント開始になり値が捨てられる(緑デフォルト残り)。
set -g status-bg "{{ .panda.bg.hex }}"
set -g status-fg "{{ .panda.fg.hex }}"

# 左側: セッション名
set -g status-left-length 40
set -g status-left "#[fg={{ .panda.fg.hex }},bg={{ .panda.subtle.hex }},bold] #S #[fg={{ .panda.subtle.hex }},bg={{ .panda.bg.hex }}]"

# 右側: 日時
set -g status-right-length 150
set -g status-right "#[fg={{ .panda.subtle.hex }},bg={{ .panda.bg.hex }}]#[fg={{ .panda.fg.hex }},bg={{ .panda.subtle.hex }}] %Y-%m-%d %H:%M:%S "

# ウィンドウリスト
setw -g window-status-format "#[fg={{ .panda.subtle.hex }},bg={{ .panda.bg.hex }}] #I:#W "
setw -g window-status-current-format "#[fg={{ .panda.bg.hex }},bg={{ .panda.cyan.hex }}]#[fg={{ .panda.bg.hex }},bg={{ .panda.cyan.hex }},bold] #I:#W #[fg={{ .panda.cyan.hex }},bg={{ .panda.bg.hex }}]"

# ============================
# popup でツール呼び出し
# ============================

# Prefix + g: tig をポップアップで起動(差分確認・コミット)
bind g popup -w90% -h90% -d '#{pane_current_path}' -E 'tig'

# Prefix + T / G: worktree / ghq repo を popup の fzf で選び、新 window(Enter)か pane 横分割(C-s)で開く。
# T=workTree / G=Ghq。小文字 w(=window 一覧 choose-tree)と紛らわしい W は避けた。
# 旧 zsh の Ctrl+G widget(^g^g / ^g^w)を tmux に一本化したもの。prefix は Claude Code 等の TUI
# 実行中でも tmux が先に奪うので、どの画面からでも呼べる(シェルのプロンプト専用だった ZLE と違う)。
bind T display-popup -w 90% -h 90% -b rounded \
  -S 'fg={{ .panda.cyan.hex }}' -s 'bg={{ .panda.bg.hex }}' \
  -T ' worktree (enter=window / C-s=pane) ' \
  -E '~/.config/tmux/jump.sh worktree'
bind G display-popup -w 90% -h 90% -b rounded \
  -S 'fg={{ .panda.cyan.hex }}' -s 'bg={{ .panda.bg.hex }}' \
  -T ' ghq repo (enter=window / C-s=pane) ' \
  -E '~/.config/tmux/jump.sh repo'

# Prefix + e: 永続シェル popup(トグル式)
# 同じキーで開閉。閉じてもセッション "popup" は残り、再度開くと状態が復帰する
bind e if -F '#{==:#{session_name},popup}' \
  { detach-client } \
  { popup -w90% -h90% -d '#{pane_current_path}' -E \
    'tmux new-session -A -s popup -c "#{pane_current_path}"' }

# ============================
# 操作チートシート(prefix + ?)
# ============================

# nvim の <leader>? と対の自前ヘルプ。tmux 標準の ? = list-keys を置換する。
# 中身は ~/.config/tmux/cheatsheet.sh(キュレーション静的・panda 追従・q/Esc で閉じる)。
# サイズは中身の実寸(玄人テクは毎回ランダム3件で高さ31行固定、幅は最大95cols)
# +ボーダー分に合わせた固定値。DATA を大きく増減したらこの -w/-h も合わせる。
bind ? display-popup -E -w 98 -h 34 \
  -b rounded \
  -S 'fg={{ .panda.cyan.hex }}' \
  -s 'bg={{ .panda.bg.hex }}' \
  -T ' tmux Cheatsheet ' \
  '~/.config/tmux/cheatsheet.sh'

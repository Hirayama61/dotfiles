// Zed keymap
//
// vim_mode: true 前提。Neovim の慣習(旧 prior config 設定)に揃えている。
// Reference: https://zed.dev/docs/key-bindings
// Default keymap は cmd-shift-p → "zed: open default keymap"
[
  // ===== Vim Normal mode (leader = space) =====
  {
    "context": "VimControl && !menu",
    "bindings": {
      // 基本
      "space w": "workspace::Save",
      "space q": "pane::CloseActiveItem",

      // パネル
      "space e": "project_panel::ToggleFocus",
      "space t": "terminal_panel::ToggleFocus",
      "space o": "outline_panel::ToggleFocus",
      "space g": "git_panel::ToggleFocus",
      // "space a" は AI agent panel の action 名がバージョン差あり、未設定。
      // cmd+shift+p で "agent" / "assistant" を検索し action 名を確認して追加する。

      // Pane 分割
      "space s v": "pane::SplitRight",
      "space s h": "pane::SplitDown",

      // Buffer / Tab 移動
      "tab":       "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePrevItem",

      // ファイル検索
      "space f f": "file_finder::Toggle",
      "space f g": "pane::DeploySearch",
      "space f r": "projects::OpenRecent",

      // ファイルパスコピー
      "space c p": "editor::CopyPath",
      "space c r": "editor::CopyRelativePath",
      "space c f": "editor::CopyFileName",

      // LSP
      "space c a": "editor::ToggleCodeActions",
      "space r n": "editor::Rename",

      // Diagnostic 前/次
      "[ d": "editor::GoToPreviousDiagnostic",
      "] d": "editor::GoToDiagnostic",

      // 全選択(vim default の C-a 増分は上書き)
      "ctrl-a": "editor::SelectAll"
    }
  },

  // ===== Workspace (global) =====
  {
    "context": "Workspace",
    "bindings": {
      // Pane 間移動
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },

  // ===== ファイル未オープン時(Workspace で Editor 外) =====
  // VimControl が発火しないので leader 系の主要なものを別途バインド
  {
    "context": "Workspace && !Editor",
    "bindings": {
      "space e":   "project_panel::ToggleFocus",
      "space t":   "terminal_panel::ToggleFocus",
      "space g":   "git_panel::ToggleFocus",
      "space f f": "file_finder::Toggle",
      "space f g": "pane::DeploySearch",
      "space f r": "projects::OpenRecent"
    }
  }
]
